{
  "manifest_version": 3,
  "name": "Smart Text Highlighter",
  "version": "1.0",
  "description": "Highlight text based on URL and regex patterns",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}